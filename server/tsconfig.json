{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "react"]
  },
  "include": ["src/**/*", "emails", "src/types"],
  "exclude": ["node_modules", "src/generated", "generated"]
}